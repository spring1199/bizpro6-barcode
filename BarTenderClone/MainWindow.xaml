<Window x:Class="BarTenderClone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BarTenderClone"
        xmlns:vm="clr-namespace:BarTenderClone.ViewModels"
        xmlns:views="clr-namespace:BarTenderClone.Views"
        xmlns:converters="clr-namespace:BarTenderClone.Converters"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="BizPro6 Barcode"
        Height="800" Width="1440"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        FontFamily="pack://application:,,,/BizPro6Barcode;component/Fonts/#Inter, Segoe UI, sans-serif">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:LabelPreviewViewModel}">
            <views:LabelPreviewView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <views:PlaceholderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/> <!-- Left Sidebar -->
            <ColumnDefinition Width="*"/>    <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Width="240"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Logo/Header -->
                    <RowDefinition Height="*"/>    <!-- Menu Items -->
                    <RowDefinition Height="Auto"/> <!-- Bottom Section -->
                </Grid.RowDefinitions>

                <!-- 1. Header with App Logo & Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,24,24,16" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Background="{DynamicResource AccentBrush}"
                            CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="🏷️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="BizPro6 Barcode" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- 2. Menu Buttons -->
                <StackPanel Grid.Row="1" Margin="12,16,12,16">
                    <RadioButton Style="{StaticResource SidebarTabButtonStyle}"
                                 IsChecked="True"
                                 Command="{Binding SwitchToProductDataCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource MenuProductData}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarTabButtonStyle}"
                                 Margin="0,8,0,0"
                                 Command="{Binding SwitchToLabelDesignerCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📐" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource MenuLabelDesigner}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarTabButtonStyle}"
                                 Margin="0,8,0,0"
                                 Command="{Binding SwitchToHistoryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource MenuHistory}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarTabButtonStyle}"
                                 Margin="0,8,0,0"
                                 Command="{Binding SwitchToSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,12,0" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource MenuSettings}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- 3. Bottom controls -->
                <StackPanel Grid.Row="2" Margin="20,16,20,24">
                    <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <!-- Language Selection -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🌐" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource LanguageSidebar}" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Height="28" Width="90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Padding="6,2"
                                  FontSize="11"/>
                    </Grid>

                    <!-- Dark Mode Toggle -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🌙" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource TextDarkMode}" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsOn="{Binding IsDarkMode, Mode=TwoWay}"
                                         OnContent="{x:Null}" OffContent="{x:Null}"
                                         Width="50" MinWidth="0" Margin="0" VerticalAlignment="Center"
                                         HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Logout Button inside sidebar -->
                    <Button Content="{DynamicResource BtnLogout}"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="32"
                            Margin="0,0,0,16"
                            VerticalAlignment="Center"/>

                    <!-- Version Info -->
                    <TextBlock Text="{DynamicResource AppVersion}" FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
