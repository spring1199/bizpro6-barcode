<Window x:Class="BarTenderClone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BarTenderClone"
        xmlns:vm="clr-namespace:BarTenderClone.ViewModels"
        xmlns:views="clr-namespace:BarTenderClone.Views"
        xmlns:converters="clr-namespace:BarTenderClone.Converters"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="BizPro6 Barcode" 
        Height="768" Width="1280" 
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:LabelPreviewViewModel}">
            <views:LabelPreviewView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>
        
        <!-- Top Application Bar -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="3" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- App Title with Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon/Logo -->
                    <Border Width="32" Height="32" Background="{StaticResource AccentBrush}" 
                            CornerRadius="4" Margin="0,0,12,0">
                        <TextBlock Text="🏷️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- App Name -->
                    <TextBlock Text="BizPro6 Barcode" 
                               Style="{StaticResource AppTitleStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Menu Items (Optional - can add File, Edit, View, Help) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Add menu items here if needed -->
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
