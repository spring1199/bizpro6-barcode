<Application x:Class="BarTenderClone.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BarTenderClone.Converters"
             xmlns:local="clr-namespace:BarTenderClone"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             DispatcherUnhandledException="OnDispatcherUnhandledException">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
                <ResourceDictionary Source="Styles/LightColors.xaml"/>
                <ResourceDictionary Source="Styles/Strings.mn.xaml"/>
                <ResourceDictionary Source="Styles/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IncrementConverter x:Key="IncrementConverter"/>
            <converters:BoolToVisConverter x:Key="BoolToVisConverter"/>
            <converters:EnumToVisConverter x:Key="EnumToVisConverter"/>
            <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
            <converters:StringToVisConverter x:Key="StringToVisConverter"/>
            <converters:BarcodeToImageConverter x:Key="BarcodeToImageConverter"/>
            <converters:QrCodeToImageConverter x:Key="QrCodeToImageConverter"/>
            <converters:Base64ImageToImageSourceConverter x:Key="Base64ImageToImageSourceConverter"/>
            <converters:BoolToExpandIconConverter x:Key="BoolToExpandIconConverter"/>
            <converters:FontScaleConverter x:Key="FontScaleConverter"/>
            <converters:PixelToMmConverter x:Key="PixelToMmConverter"/>
            <converters:ZeroToAutoLengthConverter x:Key="ZeroToAutoLengthConverter"/>
            <converters:DesignerElementGeometryConverter x:Key="DesignerElementGeometryConverter"/>
            <converters:EnumToLocalizedResourceConverter x:Key="EnumToLocalizedResourceConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
