<UserControl x:Class="BarTenderClone.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header and Stats -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Header and Statistics -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Stats Cards -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- Total Card -->
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20,15" Margin="0,0,15,0" Width="180">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HistoryTotalPrints}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalPrints}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Success Card -->
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20,15" Margin="0,0,15,0" Width="180">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HistorySuccess}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SuccessfulPrints}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Failed Card -->
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20,15" Width="180">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HistoryFailed}" Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding FailedPrints}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Search and Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource SearchTextBoxStyle}" 
                         ui:ControlHelper.PlaceholderText="{DynamicResource HistorySearchPlaceholder}" 
                         Width="250" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <Button Content="{DynamicResource BtnClearHistory}" Command="{Binding ClearHistoryCommand}" 
                         Style="{StaticResource DestructiveButtonStyle}" 
                         Height="32" Padding="15,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding FilteredEntries}" 
                      Style="{StaticResource ModernDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                      CellStyle="{StaticResource ModernCellStyle}"
                      RowStyle="{StaticResource ModernRowStyle}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource HistoryColDate}" Binding="{Binding PrintDate, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150"/>
                    <DataGridTextColumn Header="{DynamicResource HistoryColProductCode}" Binding="{Binding ProductCode}" Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource HistoryColProductName}" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource HistoryColRfid}" Binding="{Binding RfidData}" Width="200"/>
                    <DataGridTextColumn Header="{DynamicResource HistoryColQtyRequested}" Binding="{Binding QuantityRequested}" Width="80"/>
                    <DataGridTextColumn Header="{DynamicResource HistoryColQtySucceeded}" Binding="{Binding QuantitySucceeded}" Width="90"/>
                    <DataGridTemplateColumn Header="{DynamicResource HistoryColStatus}" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Success}" Value="False">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource HistoryStatusSuccess}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Success}" Value="False">
                                                        <Setter Property="Text" Value="{DynamicResource HistoryStatusError}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
