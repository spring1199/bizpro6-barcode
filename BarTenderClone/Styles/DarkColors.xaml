<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Primary Colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#8CE1FF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#30B5F4"/>
    
    <!-- Neutral Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#333333"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#434343"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#6B6B6B"/>
    
    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FCE100"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF99A4"/>
    
    <!-- DataGrid Colors -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#004A83"/>
    <SolidColorBrush x:Key="ZebraStripeBrush" Color="#282828"/>

    <!-- Premium UI Colors -->
    <SolidColorBrush x:Key="SelectionGlowBrush" Color="#8CE1FF"/>
    <SolidColorBrush x:Key="HandleBorderBrush" Color="#60CDFF"/>
    <SolidColorBrush x:Key="HandleFillBrush" Color="#2D2D2D"/>
    
    <!-- Sidebar Colors -->
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#383838"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#004A83"/>
    <SolidColorBrush x:Key="SidebarSelectedTextBrush" Color="#60CDFF"/>
</ResourceDictionary>
