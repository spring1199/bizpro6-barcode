<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Primary Colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#106EBE"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E"/>
    
    <!-- Neutral Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E1E1E1"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#605E5C"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#A19F9D"/>
    
    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#107C10"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FF8C00"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D13438"/>
    
    <!-- DataGrid Colors -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#E5F3FF"/>
    <SolidColorBrush x:Key="ZebraStripeBrush" Color="#FAFAFA"/>

    <!-- Premium UI Colors -->
    <SolidColorBrush x:Key="SelectionGlowBrush" Color="#4DA8FF"/>
    <SolidColorBrush x:Key="HandleBorderBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="HandleFillBrush" Color="#FFFFFF"/>
    
    <!-- Sidebar Colors -->
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#EAEAEA"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#E5F3FF"/>
    <SolidColorBrush x:Key="SidebarSelectedTextBrush" Color="#0078D4"/>
</ResourceDictionary>
